# Skopiuj do .env i dostosuj.

# --- Django ---
SECRET_KEY=zmien-mnie-na-dlugi-losowy-ciag
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://skryba.twojadomena.pl

# --- Produkcja (gdy DEBUG=false) ---
# Port hosta, na którym nasłuchuje web (na Mikrusie = Twój przydzielony port).
WEB_PORT=8000
# Za reverse proxy (Caddy/nginx/Mikrus) Django rozpoznaje HTTPS po nagłówku
# X-Forwarded-Proto. Jeśli pojawią się pętle przekierowań, ustaw na false.
SECURE_SSL_REDIRECT=true

# --- Baza danych ---
# Pusto = SQLite. Aby użyć PostgreSQL (faza RAG):
# DATABASE_URL=postgres://skryba:haslo@db:5432/skryba

# --- OCR ---
# Domyślny tryb: fast (CPU/Tesseract) lub quality (GPU/chmura)
OCR_DEFAULT_MODE=fast
OCR_TESSERACT_LANG=pol+eng

# --- Ollama (tryb QUALITY) ---
# UWAGA (Linux + Docker): aby kontener widział Ollamę na hoście, Ollama musi
# słuchać na 0.0.0.0, nie tylko na 127.0.0.1. Ustaw na HOŚCIE OLLAMA_HOST=0.0.0.0
#   systemd:  sudo systemctl edit ollama  ->  [Service]\n  Environment="OLLAMA_HOST=0.0.0.0:11434"
#             sudo systemctl daemon-reload && sudo systemctl restart ollama
#   ręcznie:  OLLAMA_HOST=0.0.0.0 ollama serve
# Test z kontenera:  docker compose exec worker python -c "import requests;print(requests.get('http://host.docker.internal:11434/api/tags').status_code)"  (oczekiwane: 200)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OCR_OLLAMA_MODEL=kimi-k2.6:cloud
# Wymagane dla Ollama Cloud:
# OLLAMA_API_KEY=twoj-klucz
OCR_OLLAMA_TIMEOUT=300

# --- Worker ---
Q_WORKERS=2

# --- Ekstrakcja metadanych (faza 2) ---
# Model LLM do klasyfikacji i wyciągania pól (data, kwota, kontrahent…)
EXTRACT_OLLAMA_MODEL=gemma4:31b-cloud

# --- Obserwator katalogu (opcjonalny, profil 'inbox') ---
INBOX_DIR=/app/data/inbox
INBOX_POLL_SECONDS=10
INBOX_MODE=fast

# --- PostgreSQL + pgvector (faza 3, wymagane) ---
POSTGRES_DB=skryba
POSTGRES_USER=skryba
POSTGRES_PASSWORD=zmien-to-haslo
DATABASE_URL=postgres://skryba:zmien-to-haslo@db:5432/skryba

# --- Wyszukiwanie semantyczne / RAG (faza 3) ---
EMBED_OLLAMA_MODEL=nomic-embed-text
EMBED_DIM=768
RAG_OLLAMA_MODEL=gemma4:31b-cloud
# Konfiguracja FTS Postgresa ('simple' bez słowników; można podmienić)
SEARCH_CONFIG=polish
